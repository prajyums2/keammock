# ============================================
# KEAM Mock Test Platform - Environment Variables
# ============================================

# Server Configuration
PORT=8080
NODE_ENV=development

# Database (MongoDB Atlas or local)
# Local: mongodb://localhost:27017/gate_mock
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/gate_mock
MONGODB_URI=mongodb://localhost:27017/gate_mock

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS Origins (comma-separated for multiple domains)
# Examples:
# - Development: http://localhost:5173,http://localhost:5174
# - Vercel: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend URL (for references in emails, etc.)
FRONTEND_URL=http://localhost:5173

# ============================================
# DEPLOYMENT SPECIFIC
# ============================================

# For Railway Deployment:
# PORT=8080
# NODE_ENV=production
# CORS_ORIGINS=https://your-app.vercel.app

# For Vercel Frontend (.env.production):
# VITE_API_URL=https://your-railway-app.up.railway.app/api
